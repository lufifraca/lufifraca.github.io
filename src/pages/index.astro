---
import Header from "../components/Header.astro";
import Rift from "../components/Rift.astro";
import MilanFeature from "../components/MilanFeature.astro";
import { SITE_TITLE, SITE_DESCRIPTION, RESUME_SWE } from "../consts";
import { ClientRouter } from "astro:transitions";
---
<html lang="en" data-world="product">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{SITE_TITLE}</title>
    <meta name="description" content={SITE_DESCRIPTION} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/site.css" />
    <ClientRouter />
    <style>
      :target { scroll-margin-top: 110px; }

      main.home {
        position: relative;
      }

      /* ============== HERO ============== */
      .hero {
        position: relative;
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: clamp(24px, 4vw, 64px);
        align-items: end;
        padding: clamp(48px, 8vw, 120px) 0 clamp(60px, 10vw, 120px);
        min-height: calc(100vh - 110px);
      }

      .hero-mark {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted-strong);
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: clamp(14px, 2vw, 28px);
      }

      .hero-mark::before {
        content: "";
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--accent);
        box-shadow: 0 0 0 4px var(--accent-soft);
        animation: blink 2.6s ease-in-out infinite;
      }

      @keyframes blink {
        0%, 60%, 100% { opacity: 1; }
        30% { opacity: 0.25; }
      }

      .hero h1 {
        font-family: var(--font-display);
        font-variation-settings: "opsz" 144, "SOFT" 40, "wght" 500;
        font-size: clamp(3.4rem, 11vw, 10rem);
        line-height: 0.88;
        letter-spacing: -0.04em;
        margin: 0 0 clamp(18px, 3vw, 32px);
        color: var(--text);
      }

      .hero h1 .line { display: block; }

      .hero h1 .accent {
        font-style: italic;
        font-variation-settings: "opsz" 144, "SOFT" 80, "wght" 500;
        color: var(--accent);
        padding-right: 0.1em;
      }

      .hero-tagline {
        font-family: var(--font-body);
        font-size: clamp(1.05rem, 1.6vw, 1.35rem);
        line-height: 1.5;
        max-width: 46ch;
        color: var(--text-soft);
        margin: 0 0 clamp(24px, 4vw, 40px);
      }

      .hero-tagline strong {
        font-weight: 600;
        color: var(--text);
      }

      .hero-ctas {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }

      /* Photo (kept from the old index) */
      .hero-photo {
        position: relative;
        justify-self: end;
        width: 100%;
        max-width: 420px;
        aspect-ratio: 4 / 5;
      }

      .hero-photo-frame {
        position: absolute;
        inset: 0;
        border: 2px solid var(--ink);
        border-radius: 4px;
        overflow: hidden;
        background: var(--card);
        transform: rotate(-1.5deg);
        box-shadow: 14px 14px 0 0 var(--ink);
        transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.4s ease;
      }

      .hero-photo:hover .hero-photo-frame {
        transform: rotate(0deg) translate(-4px, -4px);
        box-shadow: 18px 18px 0 0 var(--accent);
      }

      .hero-photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .hero-photo-tape {
        position: absolute;
        top: -14px;
        left: 50%;
        transform: translateX(-50%) rotate(-2deg);
        width: 120px;
        height: 28px;
        background: rgba(255, 220, 120, 0.85);
        border: 1px solid rgba(0, 0, 0, 0.08);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        z-index: 2;
      }

      .hero-photo-caption {
        position: absolute;
        bottom: -38px;
        right: 12px;
        font-family: var(--font-mono);
        font-size: 0.7rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .cartridge {
        position: absolute;
        left: -24px;
        bottom: -24px;
        width: 120px;
        height: 72px;
        background: linear-gradient(180deg, #2b2f44 0%, #1a1d2e 100%);
        border: 2px solid var(--ink);
        border-radius: 4px 4px 8px 8px;
        transform: rotate(-6deg);
        box-shadow: 6px 6px 0 0 var(--ink);
        z-index: 3;
        display: grid;
        grid-template-rows: 1fr auto;
        padding: 8px 10px;
      }

      .cartridge::before {
        content: "";
        background: #ff7a3d;
        border: 1px solid var(--ink);
        border-radius: 2px;
      }

      .cartridge-label {
        font-family: var(--font-mono);
        font-size: 0.55rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #cfd1ea;
        text-align: center;
        padding-top: 4px;
      }

      /* ============== WHAT I DO ============== */
      .bio {
        padding: clamp(64px, 10vw, 140px) 0;
        border-top: 1px solid var(--border);
        text-align: center;
      }

      .bio__inner {
        max-width: 64ch;
        margin: 0 auto;
      }

      .bio__kicker {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted-strong);
        margin: 0 0 clamp(16px, 2vw, 24px);
      }

      .bio h2 {
        font-family: var(--font-display);
        font-variation-settings: "opsz" 144, "SOFT" 30, "wght" 500;
        font-size: clamp(2.2rem, 5vw, 3.6rem);
        line-height: 1;
        letter-spacing: -0.03em;
        margin: 0 0 clamp(20px, 3vw, 32px);
      }

      .bio h2 em {
        font-style: italic;
        color: var(--accent);
      }

      .bio p {
        font-family: var(--font-body);
        font-size: clamp(1rem, 1.4vw, 1.15rem);
        line-height: 1.65;
        color: var(--text-soft);
        margin: 0 0 16px;
      }

      .bio p strong {
        font-weight: 600;
        color: var(--text);
      }

      .bio p em {
        font-style: italic;
        color: var(--accent);
      }

      .bio__thesis {
        margin-top: clamp(24px, 3vw, 36px);
        padding-top: clamp(16px, 2vw, 24px);
        border-top: 1px dashed var(--border);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text);
      }

      /* ============== PORTALS ============== */
      .portals {
        padding: clamp(60px, 10vw, 120px) 0 clamp(80px, 12vw, 160px);
        border-top: 1px solid var(--border);
        text-align: center;
      }

      .portals__head {
        max-width: 56ch;
        margin: 0 auto clamp(40px, 6vw, 72px);
      }

      .portals__kicker {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--muted-strong);
        margin: 0 0 12px;
      }

      .portals h2 {
        font-family: var(--font-display);
        font-variation-settings: "opsz" 144, "SOFT" 30, "wght" 500;
        font-size: clamp(2.2rem, 6vw, 4rem);
        line-height: 1;
        letter-spacing: -0.03em;
        margin: 0 0 clamp(16px, 2vw, 24px);
      }

      .portals h2 em {
        font-style: italic;
        color: var(--accent);
      }

      .portals__lede {
        color: var(--text-soft);
        font-size: clamp(1rem, 1.4vw, 1.15rem);
        line-height: 1.55;
        margin: 0;
      }

      .portals__grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: clamp(32px, 5vw, 72px);
        max-width: 820px;
        margin: 0 auto;
      }

      .portals__cell {
        position: relative;
        flex: 0 1 300px;
        max-width: 320px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
      }

      .portals__label {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted-strong);
        text-align: center;
      }

      /* (halo stagger is handled inside the Rift component — the new
         oval portals are light enough that simultaneous pulses read
         as a paired beat rather than fighting.) */

      /* ============== RESPONSIVE ============== */
      @media (max-width: 900px) {
        .hero {
          grid-template-columns: 1fr;
          gap: 48px;
          padding-top: clamp(32px, 6vw, 60px);
          min-height: auto;
        }
        .hero-photo {
          justify-self: start;
          max-width: 320px;
        }
        .portals__grid {
          gap: 60px;
        }
      }

      @media (max-width: 520px) {
        .hero h1 {
          font-size: clamp(2.8rem, 14vw, 4.5rem);
        }
        .hero-photo-tape {
          width: 90px;
        }
        .hero-photo {
          max-width: 280px;
        }
        .cartridge {
          width: 100px;
          height: 60px;
          left: -14px;
          bottom: -18px;
        }
        .hero-ctas .btn {
          padding: 12px 18px;
          font-size: 0.82rem;
        }
      }
    </style>
  </head>

  <body>
    <Header world="home" />

    <main class="container home">
      <!-- ============== HERO ============== -->
      <section class="hero">
        <div class="hero-copy">
          <div class="hero-mark">
            <span>// luca_ficano_latimer · bay area</span>
          </div>

          <h1>
            <span class="line"><span class="accent">Luca</span></span>
            <span class="line">Ficano</span>
            <span class="line">Latimer.</span>
          </h1>

          <p class="hero-tagline">
            <strong>CS grad, product builder, and game designer.</strong>
            Two summers at 505 Games on <em>Among the Trolls</em>, a handful of
            shipped products, and a growing library of prototypes — currently hunting
            product, solutions, and game-design roles in the SF Bay Area or LA.
          </p>

          <div class="hero-ctas">
            <a class="btn primary" href="#milan">Milan · 505 Games →</a>
            <a class="btn ghost" href="#portals">Apps/Games</a>
          </div>
        </div>

        <div class="hero-photo">
          <div class="hero-photo-tape" aria-hidden="true"></div>
          <div class="hero-photo-frame">
            <img src="/images/luca-hero.jpg" alt="Photo of Luca Ficano Latimer" />
          </div>
          <div class="hero-photo-caption" aria-hidden="true">// luca.jpg</div>
          <div class="cartridge" aria-hidden="true">
            <div class="cartridge-label">HOME</div>
          </div>
        </div>
      </section>

      <!-- ============== WHAT I DO ============== -->
      <section class="bio" aria-labelledby="bio-heading">
        <div class="bio__inner">
          <p class="bio__kicker">// what i do</p>
          <h2 id="bio-heading">
            Design, systems, and <em>shipping things.</em>
          </h2>
          <p>
            I'm a <strong>computer science graduate from Cal Poly Pomona (Dec 2025)</strong>
            working at the intersection of game design and technical product. Most recently
            I spent two summers at <strong>505 Games / Avantgarden</strong> in Milan building
            systems for <em>Among the Trolls</em> — prototyping building and magic mechanics,
            owning the Narrative plugin for quests and dialogue, and shipping content
            toward early-access.
          </p>
          <p>
            Outside the studio I ship full-stack web products with
            <strong>TypeScript, Next.js, Python, SQL, Docker, and AWS</strong> —
            <a href={RESUME_SWE} target="_blank" rel="noreferrer">SWE resume ↗</a>.
            Fluent in Jira, Confluence, Perforce, Figma, and Italian/Spanish.
          </p>
          <p>
            Active in the California games scene — volunteered at
            <strong>GamesBeat Summit</strong> (LA) in 2025 and the
            <strong>Crossfire Lounge</strong> (SF) in 2026.
          </p>
        </div>
      </section>

      <!-- ============== MILAN CINEMATIC ============== -->
      <MilanFeature />

      <!-- ============== DUAL PORTALS ============== -->
      <section class="portals" id="portals" aria-labelledby="portals-heading">
        <div class="portals__head">
          <p class="portals__kicker">// two destinations</p>
          <h2 id="portals-heading">
            Pick your <em>portal.</em>
          </h2>
          <p class="portals__lede">
            Products and case studies live in the studio. Games and prototypes
            live in the arcade.
          </p>
        </div>

        <div class="portals__grid">
          <div class="portals__cell">
            <Rift
              variant="studio"
              href="/studio"
              label="studio."
              caption="// products · case studies"
              riftKey="studio"
              ariaLabel="Enter the studio"
            />
            <span class="portals__label">products · shipped end-to-end</span>
          </div>

          <div class="portals__cell">
            <Rift
              variant="arcade"
              href="/arcade"
              label="arcade."
              caption="// games · prototypes"
              riftKey="arcade"
              ariaLabel="Enter the arcade"
            />
            <span class="portals__label">games · prototypes</span>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
