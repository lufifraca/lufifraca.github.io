---
import Header from "../components/Header.astro";
import DynamicIsland from "../components/DynamicIsland.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects", ({ data }) => !data.draft).catch(() => []))
  .sort((a, b) => a.data.order - b.data.order);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Projects · Luca Ficano Latimer</title>
    <meta name="description" content="Game dev and CS projects" />
    <link rel="stylesheet" href="/site.css" />
    <style>
      .projects-page {
        padding-top: 32px;
      }
      .projects-heading {
        max-width: 760px;
        margin-bottom: 40px;
      }
      .projects-heading h1 {
        font-size: clamp(2.5rem, 7vw, 4.5rem);
        margin-bottom: 10px;
        letter-spacing: -1px;
      }
      .project-feature {
        margin-bottom: 110px;
      }
      .project-media {
        position: relative;
        border-radius: clamp(20px, 4vw, 34px);
        overflow: hidden;
        min-height: 420px;
        border: 1px solid var(--border);
        background: var(--bg-soft);
        box-shadow: var(--shadow-soft);
        margin-bottom: clamp(24px, 6vw, 72px);
      }
      .project-media-asset {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .project-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        padding: clamp(24px, 6vw, 60px);
        color: #fff;
        background: linear-gradient(180deg, rgba(0, 6, 32, 0) 25%, rgba(3, 9, 24, 0.85) 100%);
        text-transform: uppercase;
      }
      .project-count {
        font-size: 0.85rem;
        letter-spacing: 0.4em;
        margin-bottom: 12px;
        opacity: 0.8;
      }
      .project-overlay h2 {
        font-size: clamp(2.4rem, 8vw, 5.2rem);
        margin: 0;
        letter-spacing: -1px;
      }
      .project-overlay p {
        margin: 14px 0 0;
        text-transform: none;
        font-size: 1.1rem;
        max-width: 60ch;
        line-height: 1.6;
        opacity: 0.92;
      }
      .project-card {
        margin-top: clamp(-80px, -10vw, -20px);
        margin-left: auto;
        width: min(640px, 95%);
        background: var(--card);
        border-radius: 28px;
        border: 1px solid var(--border);
        padding: clamp(20px, 3vw, 36px);
        box-shadow: var(--shadow-soft);
        display: flex;
        flex-direction: column;
        gap: 18px;
        position: relative;
        z-index: 2;
      }
      .project-card__header {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        justify-content: space-between;
        align-items: flex-start;
      }
      .project-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }
      .project-tags span {
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 4px 10px;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .project-card__summary {
        margin: 0;
        font-size: 1rem;
      }
      .project-card__meta {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
      }
      .project-card__meta div {
        flex: 1;
        min-width: 140px;
      }
      .project-card__meta span {
        display: block;
        font-size: 0.78rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 4px;
      }
      .project-card__meta strong {
        font-size: 1.1rem;
      }
      .project-card__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }
      @media (max-width: 720px) {
        .project-card {
          margin-top: 0;
          width: 100%;
        }
        .project-media {
          margin-bottom: 24px;
        }
        .project-overlay {
          padding-bottom: 36px;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <DynamicIsland />

    <main class="container projects-page">
      <div class="projects-heading">
        <p class="kicker"></p>
        <h1>My Projects</h1>
        <p>
          
        </p>
      </div>

      {projects.map((project, index) => (
        <article class="project-feature" id={project.data.slug}>
          <div class="project-media">
            {project.data.video ? (
              <video
                class="project-media-asset"
                src={project.data.video}
                poster={project.data.thumb || undefined}
                autoplay
                muted
                loop
                playsinline
              ></video>
            ) : project.data.thumb ? (
              <img class="project-media-asset" src={project.data.thumb} alt={project.data.title} loading="lazy" />
            ) : (
              <div class="project-media-asset" style="background: #e5e7eb;"></div>
            )}
            <div class="project-overlay">
              <div class="project-count">{String(index + 1).padStart(2, "0")} / {project.data.year}</div>
              <h2>{project.data.title}</h2>
            </div>
          </div>
          <div class="project-card">
            <div class="project-card__header">
              <div>
                <div class="kicker"></div>
                <h3>{project.data.title}</h3>
              </div>
              {project.data.stack?.length ? (
                <div class="project-tags">
                  {project.data.stack.map((tech) => (
                    <span>{tech}</span>
                  ))}
                </div>
              ) : null}
            </div>
            <p class="project-card__summary">{project.data.summary}</p>
            <div class="project-card__meta">
              <div>
                <span>Year</span>
                <strong>{project.data.year}</strong>
              </div>
              <div>
                <span>Focus</span>
                <strong>{project.data.stack?.join(" / ") || "Design & Build"}</strong>
              </div>
            </div>
            <div class="project-card__actions">
              {project.data.live ? (
                <a class="btn primary" href={project.data.live} target="_blank" rel="noreferrer">Visit</a>
              ) : null}
              {project.data.repo ? (
                <a class="btn" href={project.data.repo} target="_blank" rel="noreferrer">Source</a>
              ) : null}
              
            </div>
          </div>
        </article>
      ))}
    </main>
  </body>
</html>
