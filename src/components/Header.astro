---
import { RESUME_PRODUCT, RESUME_DESIGN } from "../consts";

interface Props {
  world?: "home" | "product" | "arcade";
}

const { world = "product" } = Astro.props;
const isHome = world === "home";
const isArcade = world === "arcade";
const resumeUrl = isArcade ? RESUME_DESIGN : RESUME_PRODUCT;
const resumeLabel = isHome ? "Resume" : isArcade ? "Design CV" : "Product CV";

const contextLabel = isArcade ? "arcade" : "studio";
---

<header class="studio-header" data-world={world} aria-label="Site navigation">
  <div class="studio-header__inner">
    <a class="brand" href="/">
      <span class="brand__mark" aria-hidden="true"></span>
      <span class="brand__name">L.F.L.</span>
      {!isHome && (
        <>
          <span class="brand__slash">/</span>
          <span class="brand__context">{contextLabel}</span>
        </>
      )}
    </a>

    <nav class="nav" aria-label="Primary navigation">
      <a class="nav__link" href="/">Home</a>
      <a class="nav__link" href="/studio">Studio</a>
      <a class="nav__link" href="/arcade">Arcade</a>
      <a class="nav__link nav__link--cta" href={resumeUrl} target="_blank" rel="noreferrer">
        {resumeLabel} <span aria-hidden="true">↗</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .studio-header {
    position: sticky;
    top: 0;
    z-index: 60;
    backdrop-filter: blur(18px) saturate(140%);
    -webkit-backdrop-filter: blur(18px) saturate(140%);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid var(--border);
    transition: background 500ms ease, border-color 500ms ease;
  }

  .studio-header__inner {
    max-width: 1220px;
    margin: 0 auto;
    padding: 16px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  /* BRAND */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .brand__mark {
    width: 14px;
    height: 14px;
    border-radius: 4px;
    background: var(--accent);
    box-shadow: 3px 3px 0 0 var(--ink);
    transition: transform 0.3s ease;
  }

  .brand:hover .brand__mark {
    transform: rotate(-10deg) scale(1.1);
  }

  .brand__name {
    font-weight: 600;
  }

  .brand__slash {
    color: var(--muted);
    opacity: 0.5;
  }

  .brand__context {
    color: var(--muted-strong);
  }

  [data-world="arcade"] .brand__context {
    color: var(--accent);
    text-shadow: 0 0 8px rgba(0, 255, 209, 0.5);
  }

  /* NAV */
  .nav {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .nav__link {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-soft);
    padding: 10px 14px;
    border-radius: 8px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .nav__link:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--ink) 6%, transparent);
  }

  .nav__link--cta {
    color: var(--text);
    border: 1.5px solid var(--ink);
    margin-left: 8px;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease,
      background 0.2s ease,
      color 0.2s ease;
  }

  .nav__link--cta:hover {
    background: var(--accent);
    color: #fff;
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 0 var(--ink);
  }

  [data-world="arcade"] .nav__link--cta:hover {
    color: #070814;
  }

  @media (max-width: 680px) {
    .studio-header__inner {
      padding: 12px 18px;
      gap: 10px;
    }
    .brand__slash,
    .brand__context {
      display: none;
    }
    .nav {
      gap: 2px;
    }
    .nav__link {
      padding: 8px 10px;
      font-size: 0.72rem;
      letter-spacing: 0.04em;
    }
    .nav__link--cta {
      margin-left: 4px;
    }
  }

  @media (max-width: 440px) {
    .studio-header__inner {
      padding: 10px 14px;
      gap: 8px;
    }
    .nav {
      gap: 0;
    }
    .nav__link {
      padding: 6px 7px;
      font-size: 0.66rem;
      letter-spacing: 0.02em;
    }
    .nav__link--cta {
      padding: 7px 9px;
      margin-left: 2px;
    }
    /* Home is redundant at this width — brand mark already links home */
    .nav__link[href="/"] {
      display: none;
    }
  }
</style>

<script>
  // ------------------------------------------------------------------
  // World-swap transition handler.
  // When the user clicks a rift portal ([data-rift]) or navigates
  // between / and /arcade, we flag the incoming document so the
  // CSS ::view-transition-new(root) keyframes in site.css fire
  // a circle-reveal from the click point.
  // ------------------------------------------------------------------
  let lastRiftClick: { x: number; y: number } | null = null;

  document.addEventListener(
    "click",
    (e) => {
      const target = e.target as HTMLElement | null;
      const rift = target?.closest("[data-rift]");
      if (rift) {
        lastRiftClick = { x: e.clientX, y: e.clientY };
      }
    },
    true
  );

  document.addEventListener("astro:before-swap", (ev) => {
    // @ts-expect-error - Astro's TransitionBeforeSwapEvent
    const e = ev as { from: URL; to: URL; newDocument: Document };
    // Normalize trailing slashes so the check works on both dev and prod
    const strip = (p: string) => p.replace(/\/$/, "") || "/";
    const fromPath = strip(e.from.pathname);
    const toPath = strip(e.to.pathname);
    // Fire the rift-open animation whenever the user crosses the arcade
    // boundary — any product-world page ⇄ /arcade.
    const isWorldSwap = (fromPath === "/arcade") !== (toPath === "/arcade");

    // Always clear first so stale state never leaks into a non-swap nav
    delete e.newDocument.documentElement.dataset.worldSwap;
    e.newDocument.documentElement.style.removeProperty("--rift-x");
    e.newDocument.documentElement.style.removeProperty("--rift-y");

    if (isWorldSwap) {
      e.newDocument.documentElement.dataset.worldSwap = "true";

      // Use the recorded rift-click coords if we have them; otherwise fall
      // back to the bottom-right corner (which is where both rifts live).
      const click =
        lastRiftClick ?? {
          x: window.innerWidth * 0.88,
          y: window.innerHeight * 0.86,
        };
      const xp = (click.x / window.innerWidth) * 100;
      const yp = (click.y / window.innerHeight) * 100;
      e.newDocument.documentElement.style.setProperty("--rift-x", `${xp}%`);
      e.newDocument.documentElement.style.setProperty("--rift-y", `${yp}%`);
      lastRiftClick = null;
    }
  });
</script>

