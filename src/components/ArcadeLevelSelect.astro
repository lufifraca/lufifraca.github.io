---
// -----------------------------------------------------------------------------
// ArcadeLevelSelect — the "pick a cabinet" grid for /arcade.
// Pulls from the `projects` collection, filters to kind === "game",
// and renders each as a neon CRT arcade cabinet.
// -----------------------------------------------------------------------------
import { getCollection } from "astro:content";

const games = (
  await getCollection(
    "projects",
    ({ data }) => !data.draft && data.kind === "game"
  ).catch(() => [])
).sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
---

<section class="arcade-select" id="levels">
  <header class="arcade-select__head">
    <span class="arcade-select__mark">// SELECT CABINET</span>
    <h2 class="arcade-select__title">Level <em>Select</em></h2>
    <p class="arcade-select__sub">
      {games.length} cabinet{games.length === 1 ? "" : "s"} online · insert coin to play
    </p>
  </header>

  <div class="cabinets" role="list">
    {games.map((game, i) => (
      <a
        class="cabinet"
        href={`/projects/${game.data.slug}`}
        role="listitem"
        data-index={i}
      >
        {/* ---------- CRT SCREEN ---------- */}
        <div class="cabinet__screen">
          {game.data.video ? (
            <video
              class="cabinet__art"
              src={game.data.video}
              poster={game.data.thumb}
              muted
              autoplay
              loop
              playsinline
              preload="metadata"
            ></video>
          ) : game.data.thumb ? (
            <img
              class="cabinet__art"
              src={game.data.thumb}
              alt={`${game.data.title} cover art`}
              loading="lazy"
            />
          ) : (
            <div class="cabinet__art cabinet__art--empty">
              <span>no signal</span>
            </div>
          )}
          <div class="cabinet__scanlines" aria-hidden="true"></div>
          <div class="cabinet__crt" aria-hidden="true"></div>
          <div class="cabinet__badge">
            CAB·{String(i + 1).padStart(2, "0")}
          </div>
          <div class="cabinet__power" aria-hidden="true"></div>
        </div>

        {/* ---------- MARQUEE PLATE ---------- */}
        <div class="cabinet__plate">
          <div class="cabinet__top">
            <span class="cabinet__year">{game.data.year}</span>
            <span class="cabinet__bar" aria-hidden="true"></span>
            <span class="cabinet__engine">
              {game.data.stack?.[0] ?? "game"}
            </span>
          </div>
          <h3 class="cabinet__title">{game.data.title}</h3>
          <p class="cabinet__blurb">
            {game.data.tagline ?? game.data.summary}
          </p>
          <div class="cabinet__foot">
            <span class="cabinet__coin">▶ INSERT COIN</span>
            <span class="cabinet__arrow" aria-hidden="true">→</span>
          </div>
        </div>
      </a>
    ))}

    {/* Ghost slot — hints at more cabinets landing later */}
    <div class="cabinet cabinet--ghost" aria-hidden="true">
      <div class="cabinet__screen cabinet__screen--ghost">
        <div class="cabinet__scanlines"></div>
        <span class="cabinet__ghost-text">
          <span class="flash">▶</span> MORE CABINETS<br />COMING SOON
        </span>
      </div>
      <div class="cabinet__plate cabinet__plate--ghost">
        <span class="cabinet__ghost-plate">// prototyping</span>
      </div>
    </div>
  </div>

  <footer class="arcade-select__foot">
    <span class="arcade-select__hint">
      <span class="key">↵</span> click a cabinet to view the build
    </span>
  </footer>
</section>

<style>
  /* ========== SECTION SHELL ========== */
  .arcade-select {
    position: relative;
    padding: clamp(24px, 4vw, 48px) 0 clamp(40px, 6vw, 80px);
  }

  .arcade-select__head {
    margin-bottom: clamp(24px, 4vw, 40px);
  }

  .arcade-select__mark {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 6px 12px;
    border: 1px solid rgba(0, 255, 209, 0.4);
    border-radius: 999px;
    background: rgba(0, 255, 209, 0.05);
    text-shadow: 0 0 12px rgba(0, 255, 209, 0.5);
    margin-bottom: 18px;
  }

  .arcade-select__title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 60, "wght" 500;
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0 0 12px;
    color: var(--text);
  }

  .arcade-select__title em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 500;
    color: var(--accent);
    text-shadow: 0 0 28px rgba(0, 255, 209, 0.45);
  }

  .arcade-select__sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-strong);
    margin: 0;
  }

  /* ========== GRID ========== */
  .cabinets {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: clamp(18px, 2.4vw, 28px);
    align-items: stretch;
  }

  /* ========== CABINET ========== */
  .cabinet {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: linear-gradient(180deg, #0b0e1a 0%, #06070f 100%);
    border: 1.5px solid rgba(0, 255, 209, 0.22);
    border-radius: 14px;
    overflow: hidden;
    box-shadow:
      0 0 0 1px rgba(0, 255, 209, 0.08) inset,
      0 20px 40px -20px rgba(0, 0, 0, 0.8);
    transition:
      transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 0.3s ease,
      box-shadow 0.3s ease;
    will-change: transform;
  }

  .cabinet::before {
    /* thin cyan edge glow */
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 14px;
    box-shadow: 0 0 0 0 rgba(0, 255, 209, 0);
    pointer-events: none;
    transition: box-shadow 0.3s ease;
  }

  .cabinet:hover,
  .cabinet:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(0, 255, 209, 0.65);
    box-shadow:
      0 0 0 1px rgba(0, 255, 209, 0.25) inset,
      0 25px 60px -15px rgba(0, 0, 0, 0.9),
      0 0 40px rgba(0, 255, 209, 0.25);
    outline: none;
  }

  .cabinet:hover::before,
  .cabinet:focus-visible::before {
    box-shadow: 0 0 0 2px rgba(0, 255, 209, 0.35);
  }

  /* ========== CRT SCREEN ========== */
  .cabinet__screen {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #000;
    overflow: hidden;
    border-bottom: 1px solid rgba(0, 255, 209, 0.18);
  }

  .cabinet__art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.15) contrast(1.05);
    transition: transform 0.5s ease, filter 0.3s ease;
  }

  .cabinet:hover .cabinet__art {
    transform: scale(1.04);
    filter: saturate(1.35) contrast(1.1) brightness(1.05);
  }

  .cabinet__art--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0, 255, 209, 0.5);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    background:
      repeating-linear-gradient(
        0deg,
        rgba(0, 255, 209, 0.04) 0px,
        rgba(0, 255, 209, 0.04) 1px,
        transparent 1px,
        transparent 4px
      ),
      #050711;
  }

  .cabinet__scanlines {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0) 0px,
      rgba(0, 0, 0, 0) 2px,
      rgba(0, 0, 0, 0.32) 3px,
      rgba(0, 0, 0, 0) 3px,
      rgba(0, 0, 0, 0) 4px
    );
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  .cabinet__crt {
    /* subtle vignette + phosphor tint */
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse at center,
        rgba(0, 255, 209, 0.05) 0%,
        rgba(0, 0, 0, 0) 45%,
        rgba(0, 0, 0, 0.55) 100%
      );
    pointer-events: none;
  }

  .cabinet__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 3px 8px;
    border: 1px solid rgba(0, 255, 209, 0.5);
    background: rgba(5, 7, 17, 0.8);
    backdrop-filter: blur(4px);
    border-radius: 4px;
    text-shadow: 0 0 8px rgba(0, 255, 209, 0.6);
  }

  .cabinet__power {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #00ffd1;
    box-shadow:
      0 0 0 2px rgba(0, 255, 209, 0.2),
      0 0 12px rgba(0, 255, 209, 0.8);
    animation: cab-power 2.2s ease-in-out infinite;
  }

  @keyframes cab-power {
    0%, 100% { opacity: 0.6; }
    50%      { opacity: 1; }
  }

  /* ========== MARQUEE PLATE ========== */
  .cabinet__plate {
    position: relative;
    padding: 16px 18px 18px;
    background:
      linear-gradient(180deg, rgba(0, 255, 209, 0.04) 0%, transparent 100%),
      #0a0d1a;
  }

  .cabinet__top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(0, 255, 209, 0.75);
  }

  .cabinet__bar {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(0, 255, 209, 0.4),
      rgba(0, 255, 209, 0.05)
    );
  }

  .cabinet__engine {
    color: var(--muted-strong);
  }

  .cabinet__title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 20, "wght" 500;
    font-size: 1.55rem;
    line-height: 1.05;
    margin: 0 0 6px;
    color: #ecfffb;
    letter-spacing: -0.01em;
  }

  .cabinet:hover .cabinet__title {
    text-shadow: 0 0 18px rgba(0, 255, 209, 0.55);
  }

  .cabinet__blurb {
    margin: 0 0 14px;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-soft);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cabinet__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 10px;
    border-top: 1px dashed rgba(0, 255, 209, 0.18);
  }

  .cabinet__coin {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    text-shadow: 0 0 8px rgba(0, 255, 209, 0.5);
    animation: coin-blink 1.6s steps(1) infinite;
  }

  @keyframes coin-blink {
    0%, 65% { opacity: 1; }
    66%, 100% { opacity: 0.35; }
  }

  .cabinet__arrow {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 1rem;
    transition: transform 0.25s ease;
  }

  .cabinet:hover .cabinet__arrow {
    transform: translateX(4px);
  }

  /* ========== GHOST CABINET ========== */
  .cabinet--ghost {
    border-style: dashed;
    border-color: rgba(0, 255, 209, 0.15);
    background: rgba(5, 7, 17, 0.4);
    cursor: default;
  }

  .cabinet--ghost:hover {
    transform: none;
    border-color: rgba(0, 255, 209, 0.15);
    box-shadow:
      0 0 0 1px rgba(0, 255, 209, 0.08) inset,
      0 20px 40px -20px rgba(0, 0, 0, 0.8);
  }

  .cabinet__screen--ghost {
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      repeating-linear-gradient(
        0deg,
        rgba(0, 255, 209, 0.03) 0px,
        rgba(0, 255, 209, 0.03) 1px,
        transparent 1px,
        transparent 5px
      ),
      #050711;
  }

  .cabinet__ghost-text {
    position: relative;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(0, 255, 209, 0.55);
    text-align: center;
    line-height: 1.8;
  }

  .cabinet__ghost-text .flash {
    animation: coin-blink 1.2s steps(1) infinite;
    color: var(--accent);
    margin-right: 4px;
  }

  .cabinet__plate--ghost {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px 18px;
  }

  .cabinet__ghost-plate {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ========== FOOTER HINT ========== */
  .arcade-select__foot {
    margin-top: clamp(24px, 4vw, 36px);
    display: flex;
    justify-content: center;
  }

  .arcade-select__hint {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-strong);
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .arcade-select__hint .key {
    display: inline-grid;
    place-items: center;
    min-width: 22px;
    height: 22px;
    padding: 0 6px;
    border: 1px solid rgba(0, 255, 209, 0.4);
    border-radius: 4px;
    color: var(--accent);
    font-size: 0.8rem;
  }

  /* ========== REDUCED MOTION ========== */
  @media (prefers-reduced-motion: reduce) {
    .cabinet__power,
    .cabinet__coin,
    .cabinet__ghost-text .flash {
      animation: none !important;
    }
    .cabinet:hover {
      transform: none;
    }
    .cabinet:hover .cabinet__art {
      transform: none;
    }
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 520px) {
    .cabinets {
      grid-template-columns: 1fr;
    }
    .cabinet__title {
      font-size: 1.4rem;
    }
  }
</style>
