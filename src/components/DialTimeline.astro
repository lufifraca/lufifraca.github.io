---
const { items = [] } = Astro.props;
const total = items.length || 1;
---
<section id="about" class="dial-timeline" aria-label="Experience timeline" data-dial-root>
  <div class="dial-heading">
    <p class="kicker"></p>
    <h2>About me</h2>
    <p>
      I am Luca Ficano Latimer, a computer science graduate (December 2025) focused on game design and technical product work. I recently interned at 505 Games and Avantgarden on Among the Trolls, a first person survival adventure, where I built 3 dungeon prototype levels, created modular dungeon assets with smart open and close behaviors, and became the go to person for the Narrative plugin to keep quests and dialogues flowing end to end. I also prototyped building and magic mechanics, then documented them in Confluence with clear flows and edge cases so engineers could implement quickly and safely.

I like roles where design, systems, and communication intersect. I am comfortable working in Jira, Confluence, Perforce, and Figma, and I also build and ship web projects using SQL, Python, TypeScript, Next.js, Docker, AWS, and GitHub Pages. I am currently targeting game design roles and product or solutions roles, including inside AI companies, in the SF Bay Area, with flexibility for Los Angeles or Irvine.
    </p>
    <span id="timeline-target" class="dial-anchor" aria-hidden="true"></span>
  </div>
  <div class="dial-stage">
        <aside class="dial-side">
      <div class="dial-side__prompt">Drag to browse</div>
      <div class="dial-side__control">
        <div class="dial-side__dates">
          {items.map((item, index) => (
            <button type="button" class="dial-side__date" data-index={index}>
              {item.date}
            </button>
          ))}
        </div>
      </div>
    </aside>
    <div class="dial-wheel" data-total={items.length} style="--radius: clamp(240px, 38vw, 360px); --offset: 0deg;">
      {items.map((item, index) => (
        <article
          class={`dial-card ${item.link ? 'has-link' : ''}`}
          style={`--rotate:${(360 / total) * index}deg`}
          data-label={item.date}
          data-index={index}
          data-link={item.link || ''}
        >
          {item.thumb ? (
            <img class="dial-thumb" src={item.thumb} alt={item.title} loading="lazy" />
          ) : (
            <div class="dial-thumb placeholder"></div>
          )}
          <div class="dial-copy">
            <div class="kicker">{item.date}</div>
            <h3>{item.title}</h3>
            <p class="timeline-blurb" set:html={item.blurb}></p>
            {item.link && <span class="dial-link-hint">View project →</span>}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  (() => {
    const prefersReduce =
      window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function initDial(section) {
      const wheel = section.querySelector(".dial-wheel");
      const stage = section.querySelector(".dial-stage");
      const dateButtons = Array.from(section.querySelectorAll(".dial-side__date"));
      if (!wheel || !stage) return;

      const cards = Array.from(section.querySelectorAll(".dial-card"));
      const total = cards.length;
      if (!total) return;
      const maxProgress = Math.max(0, total - 1);
      const step = 360 / total;
      let progress = 0;

      const clamp = (value) => Math.min(maxProgress, Math.max(0, value));

      const setActive = (activeIndex) => {
        cards.forEach((card, idx) => card.classList.toggle("is-active", idx === activeIndex));
        dateButtons.forEach((btn, idx) => btn.classList.toggle("is-active", idx === activeIndex));
      };

      const sync = () => {
        const angle = -progress * step;
        const activeIndex = Math.round(progress);
        wheel.style.setProperty("--offset", `${angle}deg`);
        setActive(activeIndex);
      };

      const setProgress = (value) => {
        progress = clamp(value);
        sync();
      };

      // Drag/swipe support
      let isDragging = false;
      let startY = 0;
      let startProgress = 0;
      const sensitivity = 0.004; // How much drag affects progress

      const getY = (e) => {
        if (e.touches && e.touches.length) return e.touches[0].clientY;
        return e.clientY;
      };

      const onDragStart = (e) => {
        isDragging = true;
        startY = getY(e);
        startProgress = progress;
        stage.style.cursor = "grabbing";
        wheel.style.transition = "none";
      };

      const onDragMove = (e) => {
        if (!isDragging) return;
        e.preventDefault();
        const currentY = getY(e);
        const deltaY = currentY - startY;
        const newProgress = startProgress + deltaY * sensitivity * total;
        setProgress(newProgress);
      };

      const onDragEnd = () => {
        if (!isDragging) return;
        isDragging = false;
        stage.style.cursor = "";
        wheel.style.transition = "";
        // Snap to nearest card
        progress = Math.round(progress);
        progress = clamp(progress);
        sync();
      };

      // Mouse events
      stage.addEventListener("mousedown", onDragStart);
      window.addEventListener("mousemove", onDragMove);
      window.addEventListener("mouseup", onDragEnd);

      // Touch events - only engage after horizontal movement threshold
      let touchStartX = 0;
      let touchStartY = 0;
      let touchEngaged = false;

      stage.addEventListener("touchstart", (e) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchEngaged = false;
        startY = touchStartY;
        startProgress = progress;
      }, { passive: true });

      stage.addEventListener("touchmove", (e) => {
        const dx = Math.abs(e.touches[0].clientX - touchStartX);
        const dy = Math.abs(e.touches[0].clientY - touchStartY);

        // If user moved more horizontally, engage dial dragging
        if (!touchEngaged && dx > 15 && dx > dy) {
          touchEngaged = true;
          isDragging = true;
          wheel.style.transition = "none";
        }

        if (touchEngaged && isDragging) {
          e.preventDefault();
          const currentY = e.touches[0].clientY;
          const deltaY = currentY - startY;
          const newProgress = startProgress + deltaY * sensitivity * total;
          setProgress(newProgress);
        }
        // Otherwise allow normal page scroll
      }, { passive: false });

      stage.addEventListener("touchend", () => {
        if (touchEngaged) {
          onDragEnd();
        }
        touchEngaged = false;
      });

      // Use event delegation on the dates container for robustness
      const datesContainer = section.querySelector('.dial-side__dates');
      if (datesContainer) {
        datesContainer.addEventListener('click', (e) => {
          const btn = e.target.closest('.dial-side__date');
          if (!btn || !datesContainer.contains(btn)) return;
          e.preventDefault();
          // try dataset first, then fallback to index in the current list
          let idx = Number(btn.dataset.index);
          if (!Number.isFinite(idx)) {
            const currentButtons = Array.from(datesContainer.querySelectorAll('.dial-side__date'));
            idx = currentButtons.indexOf(btn);
          }
          if (!Number.isFinite(idx) || idx < 0) return;
          idx = Math.min(Math.max(0, idx), maxProgress);
          setProgress(idx);
        });
      }

      // Click handler for cards with links
      cards.forEach((card) => {
        card.addEventListener('click', (e) => {
          // Don't navigate if user was dragging
          if (isDragging) return;
          const link = card.dataset.link;
          if (link && card.classList.contains('is-active')) {
            window.location.href = link;
          }
        });
      });

      if (prefersReduce) {
        setActive(0);
        return;
      }

      sync();
    }

    function initAll() {
      document.querySelectorAll("[data-dial-root]").forEach((section) => initDial(section));
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAll, { once: true });
    } else {
      initAll();
    }
  })();
</script>

<style>
  .dial-timeline {
    padding: 32px 0 96px;
    position: relative;
  }
  .dial-anchor {
    display: block;
    width: 1px;
    height: 1px;
    margin: 0;
    scroll-margin-top: clamp(96px, 12vh, 160px);
  }
  .dial-heading {
    max-width: 620px;
    margin-bottom: 32px;
  }
  .dial-heading h2 {
    margin-bottom: 8px;
    font-size: clamp(2rem, 5vw, 3rem);
  }
  .dial-stage {
    position: relative;
    height: clamp(480px, 80vh, 720px);
    perspective: 1400px;
    overflow: visible;
    margin-top: clamp(120px, 12vw, 200px);
    cursor: grab;
    user-select: none;
  }
  .dial-wheel {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    z-index: 0;
    --offset: 0deg;
    --radius: clamp(220px, 35vw, 340px);
    --wheel-offset-y: clamp(90px, 12vw, 160px);
    transform: translateY(var(--wheel-offset-y)) translateZ(-60px) rotateX(var(--offset));
    transition: transform 0.4s ease;
    transform-origin: center;
  }
  .dial-card {
    position: absolute;
    top: 50%;
    left: 50%;
    width: min(520px, 90vw);
    border-radius: 24px;
    padding: 18px;
    border: 1px solid var(--border);
    background: var(--card, #fff);
    isolation: isolate;
    overflow: hidden;
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 18px;
    transform-style: preserve-3d;
    transform-origin: center;
    transform: translate(-50%, -50%) rotateX(var(--rotate)) translateZ(var(--radius));
    box-shadow: var(--shadow);
    opacity: 0.3;
    filter: blur(1.2px);
    transition: transform 0.4s ease, opacity 0.4s ease, filter 0.4s ease;
    backface-visibility: hidden;
    pointer-events: none;
  }
  .dial-card.is-active {
    opacity: 1;
    filter: none;
    transform: translate(-50%, -50%) rotateX(var(--rotate)) translateZ(calc(var(--radius) + 40px));
    pointer-events: auto;
  }
  .dial-card.has-link.is-active {
    cursor: pointer;
  }
  .dial-card.has-link.is-active:hover {
    border-color: var(--accent);
  }
  .dial-link-hint {
    display: block;
    margin-top: 10px;
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }
  .dial-card.has-link.is-active:hover .dial-link-hint {
    opacity: 1;
  }
  .dial-thumb {
    width: 100%;
    height: 160px;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: #d8defd;
  }
  .dial-thumb.placeholder {
    background: rgba(46, 92, 255, 0.08);
  }
  .dial-copy h3 {
    margin: 6px 0;
    font-size: 1.3rem;
  }
  .dial-copy .timeline-blurb {
    margin-bottom: 0;
  }
  @media (max-width: 720px) {
    .dial-card {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .dial-thumb {
      height: 200px;
    }
  }

  .dial-side {
    position: absolute;
    top: 50%;
    right: clamp(-10px, -2vw, 16px);
    transform: translateY(-50%);
    z-index: 20;
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 18px 20px;
    box-shadow: var(--shadow);
  }
  .dial-side__prompt {
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
  }
  .dial-side__control {
    display: flex;
    align-items: center;
    gap: 14px;
    height: clamp(280px, 55vh, 420px);
  }
  .dial-side__dates {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }
  .dial-side__date {
    background: transparent;
    border: none;
    padding: 4px 10px;
    text-align: left;
    color: var(--muted);
    font-size: 0.85rem;
    cursor: pointer;
  }
  .dial-side__date.is-active {
    color: var(--accent);
    font-weight: 600;
  }
</style>
