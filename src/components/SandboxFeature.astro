---
// Cinematic full-bleed feature section spotlighting the current role:
// Forward Deployed Engineer (contract) on the Creator Platform team at
// The Sandbox. Built as a sibling to MilanFeature, but with a cool
// cyan/voxel "metaverse" palette to set the current role apart from the
// warm Milan internships and nod to The Sandbox's brand.
//
// Media slots are clearly-marked placeholders: drop an <img> into
// `.sandbox__screen` (a screenshot/capture of the work) and the empty
// state disappears automatically via `:has(img)`. No image is required
// for the section to look finished.
---

<section class="sandbox" id="sandbox" aria-labelledby="sandbox-heading">
  <div class="sandbox__backdrop" aria-hidden="true">
    <div class="sandbox__floor"></div>
    <div class="sandbox__glow"></div>
    <div class="sandbox__scrim"></div>
    <div class="sandbox__grain"></div>
  </div>

  <div class="sandbox__content">
    <p class="sandbox__kicker">
      <span class="sandbox__dot" aria-hidden="true"></span>
      // apr 2026 — present · contract
      <span class="sandbox__now">● now</span>
    </p>

    <h2 id="sandbox-heading" class="sandbox__title">
      Forward Deployed at <em>The Sandbox.</em>
    </h2>

    <p class="sandbox__lede">
      I'm a <strong>Forward Deployed Engineer on the Creator Platform team</strong>
      — a <em>contract</em> role — and the primary technical point of contact for
      high-profile game creators building on The Sandbox's game engine, APIs, and
      SDKs. I own each integration from onboarding through stable launch.
    </p>

    <div class="sandbox__grid">
      <!-- Role panel + responsibilities -->
      <article class="sandbox-panel">
        <header class="sandbox-panel__head">
          <div class="sandbox-panel__heading">
            <h3 class="sandbox-panel__title">Forward Deployed Engineer</h3>
            <p class="sandbox-panel__org">The Sandbox · Creator Platform</p>
          </div>
          <span class="sandbox-panel__tag">Contract</span>
        </header>

        <ul class="sandbox-panel__list">
          <li>
            Primary technical point of contact for high-profile game creators
            integrating with The Sandbox's game engine, APIs, and SDKs — owning
            the relationship from onboarding through <em>stable integration</em>.
          </li>
          <li>
            Debug integration failures <em>end to end</em> across the full stack:
            reproduce issues locally, isolate root causes in client code vs.
            platform behavior, and deliver actionable repro packages to engineering.
          </li>
          <li>
            Surface undocumented API behaviors and platform edge cases through
            hands-on debugging; translate findings into internal reports that drive
            <em>SDK improvements</em> and documentation updates.
          </li>
          <li>
            Collect and triage creator-reported issues and feature gaps; synthesize
            patterns across accounts and escalate high-signal findings to product
            and engineering to <em>shape the roadmap</em>.
          </li>
        </ul>

        <div class="sandbox-panel__chips">
          <span class="sandbox-chip">Game Engine</span>
          <span class="sandbox-chip">APIs · SDKs</span>
          <span class="sandbox-chip">Full-stack debugging</span>
          <span class="sandbox-chip">Repro packages</span>
        </div>
      </article>

      <!-- Media slot: screenshot of the work -->
      <figure class="sandbox__media">
        <div class="sandbox__window">
          <div class="sandbox__windowbar" aria-hidden="true">
            <span class="sandbox__light"></span>
            <span class="sandbox__light"></span>
            <span class="sandbox__light"></span>
            <span class="sandbox__windowurl">creator-platform · the sandbox</span>
          </div>
          <div class="sandbox__screen">
            <img src="/images/thesandbox.jpg" alt="The Sandbox Creator Platform" loading="lazy" decoding="async" />
          </div>
        </div>
      </figure>
    </div>

    <footer class="sandbox__foot">
      <span class="sandbox__pill">Contract</span>
      <span class="sandbox__pill">Creator Platform</span>
      <span class="sandbox__pill">Forward Deployed</span>
      <span class="sandbox__credit">// The Sandbox · Forward Deployed Engineer</span>
    </footer>
  </div>
</section>

<style>
  .sandbox {
    position: relative;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    min-height: clamp(640px, 82vh, 940px);
    display: grid;
    align-items: center;
    padding: clamp(60px, 10vw, 140px) clamp(28px, 6vw, 96px);
    overflow: hidden;
    isolation: isolate;
    color: #eaf6ff;
    scroll-margin-top: 90px;
    background: #050a18;
  }

  /* ------------------------------------------------------------------
     Backdrop: receding voxel floor + cyan/violet glows + scrim + grain
  ------------------------------------------------------------------ */
  .sandbox__backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      radial-gradient(1100px 720px at 78% -10%, rgba(43, 168, 255, 0.22), transparent 60%),
      radial-gradient(900px 620px at 8% 110%, rgba(150, 96, 255, 0.20), transparent 60%),
      linear-gradient(180deg, #06122a 0%, #050a18 55%, #04060f 100%);
  }

  /* perspective grid "floor" sliding toward the viewer — the metaverse motif */
  .sandbox__floor {
    position: absolute;
    left: 50%;
    bottom: -14%;
    width: 240%;
    height: 78%;
    transform: translateX(-50%) perspective(620px) rotateX(64deg);
    transform-origin: bottom center;
    background-image:
      linear-gradient(to right, rgba(78, 206, 255, 0.22) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(78, 206, 255, 0.22) 1px, transparent 1px);
    background-size: 58px 58px;
    -webkit-mask-image: linear-gradient(to top, #000 0%, transparent 72%);
    mask-image: linear-gradient(to top, #000 0%, transparent 72%);
    animation: sandbox-floor 14s linear infinite;
    will-change: background-position;
  }

  @keyframes sandbox-floor {
    from { background-position: 0 0; }
    to   { background-position: 0 58px; }
  }

  .sandbox__glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(420px 420px at 82% 22%, rgba(78, 206, 255, 0.28), transparent 70%),
      radial-gradient(360px 360px at 14% 30%, rgba(168, 120, 255, 0.22), transparent 70%);
    mix-blend-mode: screen;
    animation: sandbox-breathe 9s ease-in-out infinite;
    will-change: opacity, transform;
  }

  @keyframes sandbox-breathe {
    0%, 100% { opacity: 0.85; transform: scale(1); }
    50%      { opacity: 1;    transform: scale(1.04); }
  }

  .sandbox__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(5, 10, 24, 0.92) 0%,
      rgba(5, 10, 24, 0.74) 42%,
      rgba(5, 10, 24, 0.30) 74%,
      rgba(5, 10, 24, 0.12) 100%
    );
    pointer-events: none;
  }

  .sandbox__grain {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(255, 255, 255, 0.02) 0 1px,
      transparent 1px 3px
    );
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* ------------------------------------------------------------------
     Content
  ------------------------------------------------------------------ */
  .sandbox__content {
    position: relative;
    z-index: 1;
    max-width: 1180px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    gap: clamp(20px, 3vw, 36px);
  }

  .sandbox__kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(234, 246, 255, 0.78);
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0;
  }

  .sandbox__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #4eceff;
    box-shadow:
      0 0 0 3px rgba(78, 206, 255, 0.18),
      0 0 18px rgba(78, 206, 255, 0.7);
    animation: sandbox-pulse 2.4s ease-in-out infinite;
  }

  @keyframes sandbox-pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%      { transform: scale(1.25); opacity: 0.7; }
  }

  .sandbox__now {
    margin-left: 2px;
    padding: 3px 10px;
    border-radius: 999px;
    border: 1px solid rgba(78, 206, 255, 0.5);
    background: rgba(78, 206, 255, 0.12);
    color: #aee6ff;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
  }

  .sandbox__title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 40, "wght" 500;
    font-size: clamp(3rem, 9vw, 6.6rem);
    line-height: 0.9;
    letter-spacing: -0.035em;
    margin: 0;
    max-width: 16ch;
    color: #f3fbff;
    text-shadow: 0 4px 34px rgba(0, 0, 0, 0.45);
  }

  .sandbox__title em {
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "wght" 500;
    color: #7ed8ff;
  }

  .sandbox__lede {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.55vw, 1.3rem);
    line-height: 1.6;
    max-width: 62ch;
    color: rgba(234, 246, 255, 0.92);
    margin: 0;
  }

  .sandbox__lede strong {
    color: #f3fbff;
    font-weight: 600;
  }

  .sandbox__lede em {
    font-style: italic;
    color: #7ed8ff;
  }

  /* ------------------------------------------------------------------
     Grid: role panel + media slot
  ------------------------------------------------------------------ */
  .sandbox__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(16px, 2.4vw, 32px);
    margin-top: clamp(8px, 2vw, 20px);
    align-items: stretch;
  }

  .sandbox-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    background: rgba(8, 16, 36, 0.66);
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
    border: 1px solid rgba(126, 216, 255, 0.22);
    border-radius: 8px;
    padding: clamp(22px, 2.8vw, 34px);
    box-shadow: 0 0 0 1px rgba(126, 216, 255, 0.06) inset;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.3s ease,
                box-shadow 0.35s ease;
  }

  .sandbox-panel:hover {
    transform: translateY(-4px);
    border-color: rgba(126, 216, 255, 0.5);
    box-shadow: 0 18px 50px -20px rgba(78, 206, 255, 0.45);
  }

  .sandbox-panel__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 18px;
  }

  .sandbox-panel__title {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 72, "SOFT" 30, "wght" 500;
    font-size: clamp(1.4rem, 2.1vw, 1.85rem);
    line-height: 1.05;
    margin: 0 0 6px;
    color: #f3fbff;
  }

  .sandbox-panel__org {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(234, 246, 255, 0.62);
    margin: 0;
  }

  .sandbox-panel__tag {
    flex: none;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #aee6ff;
    padding: 5px 11px;
    border: 1px solid rgba(126, 216, 255, 0.5);
    border-radius: 999px;
    background: rgba(78, 206, 255, 0.1);
  }

  .sandbox-panel__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }

  .sandbox-panel__list li {
    position: relative;
    padding-left: 22px;
    font-size: 0.94rem;
    line-height: 1.55;
    color: rgba(234, 246, 255, 0.9);
  }

  .sandbox-panel__list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.52em;
    width: 11px;
    height: 2px;
    background: #4eceff;
    box-shadow: 0 0 8px rgba(78, 206, 255, 0.7);
  }

  .sandbox-panel__list em {
    font-style: italic;
    color: #7ed8ff;
  }

  .sandbox-panel__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: clamp(18px, 2.4vw, 26px);
    padding-top: clamp(16px, 2vw, 22px);
    border-top: 1px dashed rgba(126, 216, 255, 0.22);
  }

  .sandbox-chip {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(234, 246, 255, 0.78);
    padding: 4px 10px;
    border: 1px solid rgba(126, 216, 255, 0.28);
    border-radius: 999px;
  }

  /* ------------------------------------------------------------------
     Media slot: a browser/app window mockup. Drop an <img> into
     .sandbox__screen and the empty state hides automatically.
  ------------------------------------------------------------------ */
  .sandbox__media {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
  }

  .sandbox__window {
    flex: 1;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(126, 216, 255, 0.28);
    border-radius: 10px;
    overflow: hidden;
    background: rgba(6, 12, 28, 0.72);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 24px 60px -28px rgba(78, 206, 255, 0.5);
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
                border-color 0.3s ease;
  }

  .sandbox__media:hover .sandbox__window {
    transform: translateY(-4px);
    border-color: rgba(126, 216, 255, 0.5);
  }

  .sandbox__windowbar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    border-bottom: 1px solid rgba(126, 216, 255, 0.16);
    background: rgba(10, 20, 44, 0.6);
  }

  .sandbox__light {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(126, 216, 255, 0.35);
  }
  .sandbox__light:nth-child(1) { background: #ff5f57; }
  .sandbox__light:nth-child(2) { background: #febc2e; }
  .sandbox__light:nth-child(3) { background: #28c840; }

  .sandbox__windowurl {
    margin-left: 10px;
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(234, 246, 255, 0.5);
  }

  .sandbox__screen {
    position: relative;
    flex: 1;
    min-height: clamp(260px, 36vh, 420px);
    background:
      repeating-linear-gradient(
        45deg,
        rgba(126, 216, 255, 0.05) 0 9px,
        rgba(126, 216, 255, 0.015) 9px 18px
      );
  }

  .sandbox__screen::after {
    content: "// screenshot · the sandbox";
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(126, 216, 255, 0.5);
  }

  .sandbox__screen img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    z-index: 1;
  }

  .sandbox__screen:has(img)::after {
    display: none;
  }

  /* ------------------------------------------------------------------
     Footer
  ------------------------------------------------------------------ */
  .sandbox__foot {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: clamp(12px, 2vw, 24px);
  }

  .sandbox__pill {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 6px 12px;
    border: 1px solid rgba(126, 216, 255, 0.45);
    border-radius: 999px;
    color: #aee6ff;
    background: rgba(78, 206, 255, 0.08);
  }

  .sandbox__credit {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(234, 246, 255, 0.5);
    margin-left: auto;
  }

  /* ------------------------------------------------------------------
     Responsive
  ------------------------------------------------------------------ */
  @media (max-width: 820px) {
    .sandbox {
      padding: clamp(56px, 12vw, 96px) clamp(20px, 6vw, 32px);
      min-height: auto;
    }
    .sandbox__grid {
      grid-template-columns: 1fr;
    }
    .sandbox__credit {
      margin-left: 0;
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sandbox__floor,
    .sandbox__glow,
    .sandbox__dot {
      animation: none !important;
    }
  }
</style>
